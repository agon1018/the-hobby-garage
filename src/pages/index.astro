---
import Layout from '../layouts/Layout.astro';

const rooms = [
  {
    title: 'プラモの部屋',
    lead: '制作したキットを一覧で確認して、個別ギャラリーへ移動できます。',
    href: '/plamo',
    state: '公開中',
  },
  {
    title: 'アプリの部屋',
    lead: '開発したアプリの紹介ページと仕様情報をまとめています。',
    href: '/apps',
    state: '公開中',
  },
  {
    title: '競馬の部屋',
    lead: '閲覧制限付きで馬ごとの情報を掲載予定です。',
    href: '/horse',
    state: '準備中',
  },
];
---

<Layout title="趣味のガレージ">
  <main class="portal">
    <section class="hero">
      <p class="eyebrow">Hobby Portal</p>
      <h1>趣味のガレージ</h1>
      <p class="copy">
        プラモデル、アプリ開発、競馬情報を部屋ごとに整理した個人サイトです。<br />
        まずは下のカードから各部屋へ進んでください。
      </p>
    </section>

    <section class="room-section">
      <div class="room-grid">
        {rooms.map((room) => (
          <a class="room-card" href={room.href}>
            <p class="state">{room.state}</p>
            <h2>{room.title}</h2>
            <p>{room.lead}</p>
            <span>部屋に入る</span>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  :root {
    --ink: #1f2333;
    --cloud: #fffdf8;
    --line: #d9d8d3;
    --focus: #e4572e;
    --mint: #4cb5ae;
  }

  .portal {
    min-height: 100vh;
    background:
      radial-gradient(circle at 85% 20%, rgba(76, 181, 174, 0.22), transparent 40%),
      radial-gradient(circle at 18% 80%, rgba(228, 87, 46, 0.2), transparent 40%),
      var(--cloud);
    color: var(--ink);
    font-family: 'BIZ UDPGothic', 'Noto Sans JP', sans-serif;
    padding: 2rem 1.25rem 4rem;
  }

  .hero {
    margin: 0 auto;
    max-width: 940px;
    text-align: center;
    padding: 2rem 1.4rem 1.7rem;
    border: 1px solid #e7e3d9;
    border-radius: 1.4rem;
    background:
      radial-gradient(circle at 15% 22%, rgba(76, 181, 174, 0.16), transparent 34%),
      radial-gradient(circle at 85% 78%, rgba(228, 87, 46, 0.14), transparent 34%),
      #ffffff;
    box-shadow: 0 14px 28px rgba(30, 35, 51, 0.08);
    position: relative;
    overflow: hidden;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: auto 20% 0 20%;
    height: 3px;
    background: linear-gradient(90deg, transparent, #2f9e97, #e4572e, transparent);
    opacity: 0.8;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 700;
    color: var(--focus);
    margin-bottom: 0.9rem;
  }

  h1 {
    margin: 0;
    font-family: 'Hiragino Mincho ProN', 'Yu Mincho', serif;
    font-size: clamp(1.8rem, 3.3vw, 3rem);
    letter-spacing: 0.04em;
    text-wrap: balance;
  }

  .copy {
    margin: 0.9rem auto 0;
    max-width: 740px;
    line-height: 1.75;
    font-size: 0.97rem;
  }

  .room-section {
    margin: 0.85rem auto 0;
    max-width: 1080px;
  }

  .room-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .room-card {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    position: relative;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    background: #ffffff;
    border: 1px solid var(--line);
    border-radius: 1rem;
    padding: 1.05rem 1.05rem 2.8rem;
    box-shadow: 0 10px 22px rgba(0, 0, 0, 0.05);
    overflow: hidden;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .room-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 4px;
    background: linear-gradient(90deg, #2f9e97, #4cb5ae, #e4572e);
    opacity: 0.8;
  }

  .room-card::after {
    content: '→';
    position: absolute;
    right: 1rem;
    bottom: 0.95rem;
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    border-radius: 999px;
    border: 2px solid transparent;
    background:
      linear-gradient(#ffffff, #ffffff) padding-box,
      linear-gradient(135deg, #2f9e97, #4cb5ae, #e4572e) border-box;
    color: #1f2333;
    font-weight: 700;
    font-size: 1rem;
    box-shadow: 0 8px 16px rgba(47, 158, 151, 0.25);
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .room-card:hover {
    transform: translateY(-4px);
    border-color: var(--mint);
    box-shadow: 0 14px 30px rgba(76, 181, 174, 0.2);
  }

  .room-card:hover::after,
  .room-card:focus-visible::after {
    transform: translateX(2px);
    box-shadow: 0 10px 20px rgba(47, 158, 151, 0.35);
  }

  .room-card:focus-visible {
    outline: 3px solid #2f9e97;
    outline-offset: 2px;
    transform: translateY(-4px);
  }

  .state {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--focus);
  }

  .room-card h2 {
    margin: 0;
    font-size: 1.18rem;
  }

  .room-card p {
    margin: 0;
    line-height: 1.65;
    font-size: 0.93rem;
  }

  .room-card span {
    margin-top: auto;
    font-weight: 700;
    color: #227775;
    font-size: 0.9rem;
  }

  @media (max-width: 700px) {
    .portal {
      padding: 1rem 0.8rem 2rem;
    }

    .hero {
      padding: 1.1rem 0.9rem 1.1rem;
      border-radius: 1rem;
    }

    .eyebrow {
      margin-bottom: 0.5rem;
      font-size: 0.72rem;
    }

    h1 {
      font-size: 1.5rem;
    }

    .copy {
      font-size: 0.85rem;
      line-height: 1.55;
      margin-top: 0.55rem;
    }

    .room-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.7rem;
    }

    .room-card {
      padding: 0.8rem 0.8rem 2.5rem;
      border-radius: 0.85rem;
    }

    .room-card::after {
      width: 1.75rem;
      height: 1.75rem;
      right: 0.75rem;
      bottom: 0.7rem;
      font-size: 0.88rem;
    }

    .state {
      font-size: 0.72rem;
    }

    .room-card h2 {
      font-size: 1rem;
      line-height: 1.35;
    }

    .room-card p {
      font-size: 0.82rem;
      line-height: 1.5;
    }

    .room-card span {
      font-size: 0.8rem;
    }
  }

  @media (max-width: 420px) {
    .room-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
