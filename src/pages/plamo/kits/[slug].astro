---
import Layout from '../../../layouts/Layout.astro';
import FriendPinocchioMark from '../../../components/FriendPinocchioMark.astro';
import RoomSidebar from '../../../components/RoomSidebar.astro';
import { isFriendKit, plamoKits, type KitInfo } from '../../../data/plamoKits';

export function getStaticPaths() {
  return plamoKits.map((kit) => ({ params: { slug: kit.slug }, props: { kit } }));
}

const { kit } = Astro.props as { kit: KitInfo };
---

<Layout title={`${kit.name} | プラモの部屋`}>
  <RoomSidebar
    currentPath="/plamo"
    breadcrumbs={[
      { href: '/', label: '趣味のガレージ' },
      { href: '/plamo', label: 'プラモの部屋' },
      { label: kit.name },
    ]}
  >
  <main class="page">
    <header class="head">
      <p class="status">
        <span>{kit.status}</span>
        {isFriendKit(kit) && <FriendPinocchioMark size="md" />}
      </p>
      <p class="scale">{kit.scale}</p>
      <h1>{kit.name}</h1>
      {kit.summary && <p>{kit.summary}</p>}
    </header>

    <section class="gallery-grid">
      {kit.gallery.map((image, index) => (
        <figure class="frame">
          <button
            type="button"
            class="gallery-trigger"
            aria-label={`${kit.name} ${index + 1} を拡大表示`}
          >
            <img
              src={image.src}
              alt={image.alt ?? `${kit.name} ${index + 1}`}
            />
          </button>
        </figure>
      ))}
    </section>

    <dialog id="plamo-lightbox" class="lightbox" aria-label="写真の拡大表示">
      <button type="button" class="lightbox-close" aria-label="閉じる">×</button>
      <img class="lightbox-image" src="" alt="" />
    </dialog>
  </main>
  </RoomSidebar>
</Layout>

<style>
  .page {
    min-height: 100vh;
    background: #f6f9ff;
    color: #222f4d;
    padding: 2rem 1.2rem 3rem;
    font-family: 'BIZ UDPGothic', 'Noto Sans JP', sans-serif;
  }

  .head {
    max-width: 960px;
    margin: 0 auto;
    background: #ffffff;
    border: 1px solid #d5def5;
    border-radius: 1rem;
    padding: 1.2rem;
    position: relative;
    overflow: hidden;
  }

  .status {
    margin: 0 0 0.35rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: #2f7e62;
    font-weight: 700;
  }

  .scale {
    margin: 0;
    color: #5c6ea0;
    font-weight: 700;
  }

  h1 {
    margin: 0.4rem 0 0.8rem;
    font-family: 'Hiragino Mincho ProN', 'Yu Mincho', serif;
  }

  .head p {
    line-height: 1.8;
  }

  .gallery-grid {
    max-width: 960px;
    margin: 1rem auto 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.9rem;
  }

  .frame {
    margin: 0;
    background: #fff;
    border: 1px solid #d5def5;
    border-radius: 0.8rem;
    overflow: hidden;
  }

  .gallery-trigger {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: zoom-in;
    font: inherit;
    color: inherit;
  }

  .gallery-trigger:focus-visible {
    outline: 3px solid #5ea2bb;
    outline-offset: -3px;
  }

  .gallery-trigger img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    background: #f1f5ff;
  }

  .lightbox {
    margin: auto;
    padding: 0;
    border: none;
    background: transparent;
    max-width: none;
    max-height: none;
    overflow: visible;
  }

  .lightbox::backdrop {
    background: rgba(15, 23, 42, 0.88);
  }

  .lightbox-image {
    display: block;
    max-width: min(96vw, 1200px);
    max-height: 88vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 0.5rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.45);
  }

  .lightbox-close {
    position: fixed;
    top: 0.85rem;
    right: 0.85rem;
    z-index: 1;
    width: 2.5rem;
    height: 2.5rem;
    display: grid;
    place-items: center;
    border: none;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.95);
    color: #1f2f36;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
  }

  .lightbox-close:focus-visible {
    outline: 3px solid #5ea2bb;
    outline-offset: 2px;
  }

  @media (max-width: 700px) {
    .page {
      padding: 1rem 0.8rem 2rem;
    }

    .head {
      padding: 0.9rem;
      border-radius: 0.85rem;
    }

    h1 {
      font-size: 1.25rem;
    }

    .gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.55rem;
    }

    .frame {
      border-radius: 0.65rem;
    }
  }
</style>

<script>
  function initPlamoLightbox() {
    const dialog = document.getElementById('plamo-lightbox');
    if (!dialog || dialog.dataset.bound === 'true') return;

    const lightboxImage = dialog.querySelector('.lightbox-image');
    const closeButton = dialog.querySelector('.lightbox-close');
    if (!lightboxImage || !closeButton) return;

    dialog.dataset.bound = 'true';

    document.querySelectorAll('.gallery-trigger').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const img = trigger.querySelector('img');
        if (!img) return;

        lightboxImage.src = img.currentSrc || img.src;
        lightboxImage.alt = img.alt;
        dialog.showModal();
      });
    });

    closeButton.addEventListener('click', () => dialog.close());

    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close();
    });

    dialog.addEventListener('close', () => {
      lightboxImage.removeAttribute('src');
      lightboxImage.alt = '';
    });
  }

  initPlamoLightbox();
</script>
