---
import Layout from '../../../layouts/Layout.astro';
import RoomSidebar from '../../../components/RoomSidebar.astro';
import { plamoKits, type KitInfo } from '../../../data/plamoKits';

export function getStaticPaths() {
  return plamoKits.map((kit) => ({ params: { slug: kit.slug }, props: { kit } }));
}

const { kit } = Astro.props as { kit: KitInfo };
---

<Layout title={`${kit.name} | プラモの部屋`}>
  <RoomSidebar
    currentPath="/plamo"
    breadcrumbs={[
      { href: '/', label: '趣味のガレージ' },
      { href: '/plamo', label: 'プラモの部屋' },
      { label: kit.name },
    ]}
  >
  <main class="page">
    <header class="head">
      <p class="scale">{kit.scale} / {kit.era}</p>
      <h1>{kit.name}</h1>
      <p>{kit.summary}</p>
    </header>

    <section class="gallery-grid">
      {kit.gallery.map((label, index) => (
        <figure class="frame">
          <div class="dummy-image">PHOTO {index + 1}</div>
          <figcaption>{label}</figcaption>
        </figure>
      ))}
    </section>
  </main>
  </RoomSidebar>
</Layout>

<style>
  .page {
    min-height: 100vh;
    background: #f6f9ff;
    color: #222f4d;
    padding: 2rem 1.2rem 3rem;
    font-family: 'BIZ UDPGothic', 'Noto Sans JP', sans-serif;
  }

  .head {
    max-width: 960px;
    margin: 0 auto;
    background: #ffffff;
    border: 1px solid #d5def5;
    border-radius: 1rem;
    padding: 1.2rem;
  }

  .scale {
    margin: 0;
    color: #5c6ea0;
    font-weight: 700;
  }

  h1 {
    margin: 0.4rem 0 0.8rem;
    font-family: 'Hiragino Mincho ProN', 'Yu Mincho', serif;
  }

  .head p {
    line-height: 1.8;
  }

  .gallery-grid {
    max-width: 960px;
    margin: 1rem auto 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.9rem;
  }

  .frame {
    margin: 0;
    background: #fff;
    border: 1px solid #d5def5;
    border-radius: 0.8rem;
    overflow: hidden;
  }

  .dummy-image {
    aspect-ratio: 4 / 3;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #dae5ff, #f1f5ff);
    font-size: 0.85rem;
    font-weight: 700;
    color: #51648f;
  }

  figcaption {
    padding: 0.7rem;
    font-size: 0.9rem;
  }
</style>
