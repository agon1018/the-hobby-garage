---
import Layout from '../../layouts/Layout.astro';
import FriendPinocchioMark from '../../components/FriendPinocchioMark.astro';
import RoomSidebar from '../../components/RoomSidebar.astro';
import { isFriendKit, plamoKits } from '../../data/plamoKits';
---

<Layout title="プラモの部屋">
  <RoomSidebar
    currentPath="/plamo"
    breadcrumbs={[
      { href: '/', label: '趣味のガレージ' },
      { label: 'プラモの部屋' },
    ]}
  >
  <main class="page">
    <header class="title-head">
      <p class="label">Plamo Room</p>
      <h1>プラモの部屋</h1>
      <p>制作したキット一覧です。気になるキットを選ぶと、個別のギャラリーページへ移動します。</p>
    </header>

    <section class="kit-grid">
      {plamoKits.map((kit) => (
        <a class="kit-card" href={`/plamo/kits/${kit.slug}`}>
          <img class="cover-bg" src={kit.cover} alt="" loading="lazy" decoding="async" />
          <div class="cover-overlay" aria-hidden="true"></div>
          <div class="kit-card-body">
            <p class="status">
              <span>{kit.status}</span>
              {isFriendKit(kit) && <FriendPinocchioMark />}
            </p>
            <h2>{kit.name}</h2>
            <p class="meta">スケール: {kit.scale}</p>
            {kit.note && <p class="note">{kit.note}</p>}
          </div>
          <span class="go">ギャラリーへ</span>
        </a>
      ))}
    </section>
  </main>
  </RoomSidebar>
</Layout>

<style>
  .page {
    --plamo-palette-1: #2f86a1;
    --plamo-palette-2: #7fb6c9;
    --plamo-palette-3: #2f7e62;
    --plamo-link: #1a5f73;

    min-height: 100vh;
    background:
      linear-gradient(155deg, rgba(17, 127, 166, 0.09) 0%, rgba(255, 255, 255, 0) 40%),
      #f7fbfd;
    color: #1f2f36;
    font-family: 'BIZ UDPGothic', 'Noto Sans JP', sans-serif;
    padding: 2rem 1.2rem 3.2rem;
  }

  header {
    max-width: 980px;
    margin: 0 auto 1.4rem;
  }

  .title-head {
    border: 1px solid #d7e7ee;
    border-radius: 1.15rem;
    padding: 1rem 1.15rem 1.05rem;
    background:
      radial-gradient(circle at 88% 14%, rgba(127, 182, 201, 0.24), transparent 34%),
      radial-gradient(circle at 12% 85%, rgba(47, 126, 98, 0.14), transparent 34%),
      #fcfeff;
    box-shadow: 0 12px 24px rgba(31, 99, 119, 0.08);
    position: relative;
    overflow: hidden;
  }

  .title-head::after {
    content: '';
    position: absolute;
    inset: auto 14% 0 14%;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--plamo-palette-1), var(--plamo-palette-3), transparent);
  }

  .label {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    color: var(--plamo-palette-1);
    font-weight: 700;
  }

  h1 {
    margin: 0.35rem 0 0.8rem;
    color: var(--plamo-palette-3);
    font-size: clamp(1.75rem, 3.5vw, 2.6rem);
    font-family: 'Hiragino Mincho ProN', 'Yu Mincho', serif;
    letter-spacing: 0.04em;
  }

  header p {
    line-height: 1.7;
    font-size: 0.95rem;
    margin: 0;
  }

  .kit-grid {
    max-width: 980px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .kit-card {
    display: block;
    position: relative;
    cursor: pointer;
    background: #eef4f7;
    border: 1px solid #d4e5eb;
    border-radius: 0.85rem;
    width: 100%;
    aspect-ratio: 4 / 3;
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.04);
    color: inherit;
    text-decoration: none;
    overflow: hidden;
    isolation: isolate;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .cover-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.88;
    transition: opacity 200ms ease, transform 280ms ease;
  }

  .cover-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        155deg,
        rgba(252, 254, 255, 0.38) 0%,
        rgba(247, 251, 253, 0.28) 45%,
        rgba(255, 255, 255, 0.22) 100%
      );
    transition: background 200ms ease;
  }

  .kit-card-body {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 0.6rem 0.6rem 1.85rem;
  }

  .kit-card::after {
    content: '→';
    position: absolute;
    z-index: 3;
    right: 0.6rem;
    bottom: 0.55rem;
    width: 1.65rem;
    height: 1.65rem;
    display: grid;
    place-items: center;
    border-radius: 999px;
    border: 2px solid transparent;
    background:
      linear-gradient(#ffffff, #ffffff) padding-box,
      linear-gradient(135deg, var(--plamo-palette-1), var(--plamo-palette-2), var(--plamo-palette-3)) border-box;
    color: #1f2f36;
    font-weight: 700;
    font-size: 1rem;
    box-shadow: 0 8px 16px rgba(47, 134, 161, 0.25);
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .kit-card:hover {
    transform: translateY(-4px);
    border-color: var(--plamo-palette-2);
    box-shadow: 0 12px 24px rgba(29, 102, 124, 0.2);
  }

  .kit-card:hover .cover-bg {
    opacity: 0.96;
    transform: scale(1.04);
  }

  .kit-card:hover .cover-overlay {
    background:
      linear-gradient(
        155deg,
        rgba(252, 254, 255, 0.28) 0%,
        rgba(247, 251, 253, 0.2) 45%,
        rgba(255, 255, 255, 0.16) 100%
      );
  }

  .kit-card:hover::after,
  .kit-card:focus-visible::after {
    transform: translateX(2px);
    box-shadow: 0 10px 20px rgba(47, 134, 161, 0.35);
  }

  .kit-card:focus-visible {
    outline: 3px solid #5ea2bb;
    outline-offset: 2px;
    transform: translateY(-4px);
  }

  .kit-card-body p.status {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.95rem;
    line-height: 1.2;
    color: var(--plamo-palette-3);
    font-weight: 700;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.85);
  }

  .kit-card-body p.status span {
    text-shadow: inherit;
  }

  .kit-card h2 {
    margin: 0.2rem 0;
    font-size: 0.92rem;
    line-height: 1.35;
    color: #1a2a38;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.85);
  }

  .meta {
    font-size: 0.76rem;
    color: #3d5260;
    font-weight: 600;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.85);
  }

  .kit-card-body p.meta,
  .kit-card-body p.note {
    line-height: 1.45;
    font-size: 0.78rem;
  }

  .note {
    color: #4a616d;
  }

  .go {
    position: absolute;
    z-index: 3;
    left: 0.6rem;
    bottom: 0.55rem;
    color: var(--plamo-link);
    font-weight: 700;
    font-size: 0.74rem;
    line-height: 1.65rem;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.85);
  }

  @media (max-width: 700px) {
    .page {
      padding: 1rem 0.8rem 2rem;
    }

    .back {
      margin-bottom: 0.7rem;
      font-size: 0.86rem;
    }

    .title-head {
      border-radius: 0.9rem;
      padding: 0.78rem 0.82rem 0.84rem;
    }

    .label {
      font-size: 0.72rem;
      margin-bottom: 0.25rem;
    }

    h1 {
      font-size: 1.45rem;
      margin: 0.22rem 0 0.48rem;
    }

    header p {
      font-size: 0.83rem;
      line-height: 1.5;
    }

    .kit-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.55rem;
    }

    .kit-card {
      border-radius: 0.75rem;
    }

    .kit-card-body {
      padding: 0.5rem 0.5rem 1.6rem;
    }

    .go {
      left: 0.5rem;
      bottom: 0.45rem;
      font-size: 0.68rem;
      line-height: 1.5rem;
    }

    .kit-card::after {
      width: 1.5rem;
      height: 1.5rem;
      right: 0.5rem;
      bottom: 0.45rem;
      font-size: 0.78rem;
    }

    .kit-card-body p.status {
      font-size: 0.84rem;
    }

    .kit-card h2 {
      font-size: 0.82rem;
      margin: 0.15rem 0;
    }

    .kit-card-body p.meta,
    .kit-card-body p.note {
      font-size: 0.7rem;
    }

  }

  @media (max-width: 480px) {
    .kit-grid {
      gap: 0.45rem;
    }

    .kit-card-body {
      padding: 0.42rem 0.42rem 1.45rem;
    }

    .kit-card h2 {
      font-size: 0.76rem;
    }

    .meta {
      font-size: 0.65rem;
    }

    .go {
      font-size: 0.62rem;
      line-height: 1.4rem;
    }

    .kit-card::after {
      width: 1.35rem;
      height: 1.35rem;
      font-size: 0.72rem;
    }
  }
</style>
