---
import Layout from '../../layouts/Layout.astro';
import RoomSidebar from '../../components/RoomSidebar.astro';
---

<Layout title="競馬の部屋">
  <RoomSidebar
    currentPath="/horse"
    breadcrumbs={[
      { href: '/', label: '趣味のガレージ' },
      { label: '競馬の部屋' },
    ]}
  >
  <main class="page">
    <div class="panel">
      <p class="label">Horse Room</p>
      <h1>競馬の部屋</h1>
      <p>
        このページは今後、閲覧制限付きで公開予定です。<br />
        馬ごとの成績・メモ・注目ポイントを整理できる形で実装します。
      </p>
      <p class="note">現在は準備中です。</p>
    </div>
  </main>
  </RoomSidebar>
</Layout>

<style>
  .page {
    --horse-palette-1: #7c592d;
    --horse-palette-2: #c7a26e;
    --horse-palette-3: #9a4d22;

    min-height: 100vh;
    background: #f9f8f4;
    color: #302822;
    font-family: 'BIZ UDPGothic', 'Noto Sans JP', sans-serif;
    padding: 2rem 1.2rem;
  }

  .panel {
    max-width: 760px;
    margin: 0 auto;
    background: #fff;
    border: 1px solid #e2d8ca;
    border-radius: 1rem;
    padding: 1.2rem;
    position: relative;
    overflow: hidden;
  }

  .panel::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 4px;
    background: linear-gradient(90deg, var(--horse-palette-1), var(--horse-palette-2), var(--horse-palette-3));
  }

  .label {
    margin: 0;
    text-transform: uppercase;
    color: var(--horse-palette-1);
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  h1 {
    margin: 0.4rem 0 0.8rem;
    color: var(--horse-palette-3);
    font-family: 'Hiragino Mincho ProN', 'Yu Mincho', serif;
    letter-spacing: 0.03em;
  }

  p {
    margin: 0;
    line-height: 1.8;
  }

  .note {
    margin-top: 1rem;
    font-weight: 700;
    color: var(--horse-palette-3);
  }

  .accent-link {
    color: var(--horse-palette-1);
  }

  .accent-link-secondary {
    color: var(--horse-palette-3);
  }

  @media (max-width: 700px) {
    .page {
      padding: 1rem 0.8rem;
    }

    .panel {
      border-radius: 0.9rem;
      padding: 0.82rem;
    }

    .label {
      font-size: 0.72rem;
    }

    h1 {
      font-size: 1.42rem;
      margin: 0.25rem 0 0.52rem;
    }

    p {
      font-size: 0.82rem;
      line-height: 1.55;
    }

    .note {
      margin-top: 0.65rem;
    }
  }
</style>
