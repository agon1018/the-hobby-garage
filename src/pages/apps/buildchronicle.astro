---
import Layout from '../../layouts/Layout.astro';
import RoomSidebar from '../../components/RoomSidebar.astro';

type FeatureDetail = {
  id: string;
  icon: string;
  title: string;
  lead: string;
  chips: string[];
  tip: string;
  imgs?: string[];
};

const featureDetails: FeatureDetail[] = [
  {
    id: 'project',
    icon: '📋',
    title: 'プロジェクト管理',
    lead: '作品ごとに開始日・進捗・完成状態をひとまとめに。カバー写真やテーマカラーで複数プロジェクトを直感的に識別できます。',
    chips: ['進行中 / 完成 / 保留のステータス管理', 'カバー画像とカバーカラーで視覚識別', '工程・写真・ツールをプロジェクト単位で一括参照'],
    tip: '複数キットを並行製作しても「次にやるべき作品」がすぐ分かります。',
    imgs: ['/images/buildchronicle/project.jpg'],
  },
  {
    id: 'step',
    icon: '🔧',
    title: '工程・ステップ記録',
    lead: '区分工程と子ステップの2階層で製作作業を時系列に残せます。テンプレート化で次回製作への流用も可能です。',
    chips: ['工程ごとにコメント・写真・使用色・工具を紐付け', '失敗メモ・再作業メモを記録して次回に活かす', 'よく使う工程をテンプレートとして保存・流用'],
    tip: '「表面処理 → サフ → 基本塗装 → スミ入れ」のような定番工程を一度登録すれば毎回コピーして使い回せます。',
    imgs: ['/images/buildchronicle/project_detail.jpg'],
  },
  {
    id: 'color',
    icon: '🎨',
    title: 'カラー管理・検索',
    lead: '使用塗料をメーカー別に整理し、色番号・名称で高速検索。混色比率も保存できるので完成後の再現も容易です。',
    chips: ['初期収録 120色以上 を想定', 'GSIクレオス / ガイアノーツ / タミヤ / ウォーハンマー の4社収録', '混色比率を保存してプロジェクト単位で再現レシピを管理'],
    tip: '「この赤、どうやって作った？」を後から追跡できるのが最大の狙いです。',
    imgs: ['/images/buildchronicle/color_manager_1.jpg', '/images/buildchronicle/color_manager_2.jpg'],
  },
  {
    id: 'gallery',
    icon: '📸',
    title: 'フォトギャラリー',
    lead: '製作途中と完成写真を同一プロジェクト内で整理。工程ごとの紐付けと全体ギャラリー、両方の閲覧に対応します。',
    chips: ['工程単位での写真紐付け', '撮影日時順で進捗を振り返り', 'SNS投稿用の候補写真もここから選択'],
    tip: '途中状態の比較がしやすくなり、改善点の振り返りがスムーズに行えます。',
    imgs: ['/images/buildchronicle/photo_gallery.jpg'],
  },
  {
    id: 'tool',
    icon: '🛠️',
    title: 'ツール管理',
    lead: '所持工具と消耗品を一元管理し、工程への紐付けで使用履歴も残せます。買い足しや交換時期の判断にも活用できます。',
    chips: ['初期登録 300点以上 を想定', 'タミヤ / ゴッドハンド / WAVE / GSIクレオス / ハセガワ 等をカテゴリ管理', '工程紐付けで「どの工具で仕上げたか」を記録'],
    tip: '消耗品の残量管理や工具ごとの使用回数も追えるよう設計しています。',
    imgs: ['/images/buildchronicle/tool_manager_1.jpg', '/images/buildchronicle/tool_manager_2.jpg'],
  },
  {
    id: 'wishlist',
    icon: '🛒',
    title: '欲しいものリスト',
    lead: '欲しい塗料や工具を購入候補として積み上げ。楽天市場のURLを登録して即遷移し、購入状態もアプリ内で追跡できます。',
    chips: ['楽天市場URLを登録してワンタップ遷移', '購入予定 / 検討中 / 購入済みで状態管理', 'カラー・ツールマスターからワンタップ登録'],
    tip: '製作中に見つけた候補をその場でメモして、後でまとめて比較・購入できます。',
    imgs: ['/images/buildchronicle/wishlist.jpg'],
  },
  {
    id: 'sns',
    icon: '📱',
    title: 'SNS 投稿プレビュー',
    lead: '投稿前に見せ方を確認しながら説明文とハッシュタグを準備。投稿品質を揃えつつ毎回の文章作成を省力化します。',
    chips: ['選択画像から投稿プレビューを生成', '作品名・スケール・使用色などの定型文を自動補助', 'ハッシュタグを自動付与する運用を想定'],
    tip: 'プレビューで確認 → コピー → 貼り付けで投稿するだけ。毎回の文章作成時間を大幅に短縮できます。',
    imgs: ['/images/buildchronicle/sns.jpg'],
  },
  {
    id: 'template',
    icon: '📄',
    title: 'テンプレート',
    lead: 'よく使う工程構成をテンプレートとして保存し、新規プロジェクト開始時に即適用。入力の手間を大幅に削減します。',
    chips: ['塗装中心・改造中心など製作タイプ別に保存', '新規プロジェクトにワンタップで適用', '工程のコピー・並び替えも簡単に操作可能'],
    tip: '毎回ゼロから工程を作らずに済むため、記録習慣が自然に定着します。',
    imgs: ['/images/buildchronicle/template.jpg'],
  },
];

type ScreenshotItem = {
  img: string;
  label: string;
};

const allScreenshots: ScreenshotItem[] = [
  { img: '/images/buildchronicle/project.jpg', label: 'プロジェクト一覧' },
  { img: '/images/buildchronicle/project_detail.jpg', label: 'プロジェクト詳細' },
  { img: '/images/buildchronicle/sns.jpg', label: 'SNS投稿プレビュー' },
  { img: '/images/buildchronicle/photo_gallery.jpg', label: 'フォトギャラリー' },
  { img: '/images/buildchronicle/color_manager_1.jpg', label: 'カラー管理' },
  { img: '/images/buildchronicle/tool_manager_1.jpg', label: 'ツール管理' },
  { img: '/images/buildchronicle/wishlist.jpg', label: '欲しいものリスト' },
  { img: '/images/buildchronicle/template.jpg', label: 'テンプレート' },
];
---

<Layout title="BuildChronicle - プラモデル製作記録アプリ">
  <RoomSidebar
    currentPath="/apps/buildchronicle"
    breadcrumbs={[
      { href: '/', label: '趣味のガレージ' },
      { href: '/apps', label: 'アプリの部屋' },
      { label: 'BuildChronicle' },
    ]}
  >
  <main>
    <!-- ヒーローセクション -->
    <section class="hero">
      <div class="hero-inner">
        <div class="app-icon-placeholder">BC</div>
        <h1>BuildChronicle</h1>
        <p class="tagline">プラモデル製作をもっと楽しく、もっと丁寧に記録しよう</p>
        <p class="sub-tagline">工程管理・カラー記録・写真ギャラリー・ウィッシュリストを一括管理</p>
        <div class="badge-area">
          <span class="badge">開発中</span>
          <span class="badge platform">Android / iOS / Windows 対応予定</span>
        </div>
      </div>
    </section>

    <nav class="quick-jump" aria-label="BuildChronicle ページ内目次">
      <p>クイックジャンプ</p>
      <ul>
        <li><a href="#about">アプリについて</a></li>
        <li><a href="#features">主な機能</a></li>
        <li><a href="#feature-detail">各機能の詳細</a></li>
        <li><a href="#screenshots">スクリーンショット</a></li>
        <li><a href="#rakuten">提携ショッピングサービス</a></li>
        <li><a href="#target">こんな方におすすめ</a></li>
        <li><a href="#info">開発情報</a></li>
        <li><a href="#legal">規約・ポリシー</a></li>
      </ul>
    </nav>

    <!-- アプリ概要 -->
    <section class="section" id="about">
      <div class="container">
        <h2 class="section-title">アプリについて</h2>
        <p class="section-desc">
          BuildChronicle は、プラモデルの製作記録を管理するモバイルアプリです。<br />
          複数のプロジェクトを作成し、工程ごとに使用した塗料・ツール・写真を記録できます。<br />
          製作中に気になったアイテムを欲しいものリストに追加して、楽天市場での購入もスムーズに行えます。
        </p>
      </div>
    </section>

    <!-- 主な機能 -->
    <section class="section section-alt" id="features">
      <div class="container">
        <h2 class="section-title">主な機能</h2>
        <div class="features-grid">
          {featureDetails.map((item) => (
            <a class="feature-card" href={`#fd-${item.id}`}>
              <div class="feature-icon">{item.icon}</div>
              <h3>{item.title}</h3>
              <p>{item.lead}</p>
              <span class="feature-link-hint">詳細を見る →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 機能詳細 -->
    <section class="section" id="feature-detail">
      <div class="container">
        <h2 class="section-title">各機能の詳細</h2>
        <div class="fd-grid">
          {featureDetails.map((item) => (
            <article class="fd-card" id={`fd-${item.id}`}>
              <div class="fd-accent-bar"></div>
              <div class="fd-inner">
                <div class="fd-body">
                  <div class="fd-head">
                    <span class="fd-icon">{item.icon}</span>
                    <h3>{item.title}</h3>
                  </div>
                  <p class="fd-lead">{item.lead}</p>
                  <div class="fd-chips">
                    {item.chips.map((chip) => (
                      <span class="fd-chip">{chip}</span>
                    ))}
                  </div>
                  <div class="fd-tip">{item.tip}</div>
                </div>
                <div class="fd-phone">
                  {item.imgs && item.imgs.length > 0
                    ? item.imgs.map((src) => (
                        <div class="phone-frame">
                          <div class="phone-bar"></div>
                          <div class="phone-screen">
                            <img src={src} alt={item.title} />
                          </div>
                          <div class="phone-chin"></div>
                        </div>
                      ))
                    : (
                        <div class="phone-frame">
                          <div class="phone-bar"></div>
                          <div class="phone-screen">
                            <span class="phone-placeholder-label">準備中</span>
                          </div>
                          <div class="phone-chin"></div>
                        </div>
                      )
                  }
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- スクリーンショットギャラリー -->
    <section class="section section-alt" id="screenshots">
      <div class="container">
        <h2 class="section-title">スクリーンショット</h2>
        <p class="section-desc">実際のアプリ画面をご覧いただけます。</p>
        <div class="ss-grid">
          {allScreenshots.map((s) => (
            <div class="ss-item">
              <img class="ss-img" src={s.img} alt={s.label} />
              <p class="ss-label">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ショッピングサービス連携 -->
    <section class="section" id="rakuten">
      <div class="container">
        <h2 class="section-title">提携ショッピングサービス</h2>
        <p class="section-desc" style="margin-bottom:0">
          ウィッシュリスト機能は以下の3サービスと連携しています。<br />
          欲しい塗料・ツールを登録する際に各ショッピングサービスの商品ページ URL を紐付けることができ、<br />
          アプリ内から直接商品ページへ遷移して購入できます。
        </p>
        <div class="affiliate-cards">
          <div class="affiliate-card">
            <span class="affiliate-badge" style="background:linear-gradient(135deg,#bf0000,#e00000)">楽天市場</span>
            <p>楽天アフィリエイトプログラムを通じて商品リンクを掲載しています。</p>
          </div>
          <div class="affiliate-card">
            <span class="affiliate-badge" style="background:linear-gradient(135deg,#ff8c00,#ff6600)">Yahoo! ショッピング</span>
            <p>バリューコマース経由で Yahoo! ショッピングの商品リンクを掲載しています。</p>
          </div>
          <div class="affiliate-card">
            <span class="affiliate-badge" style="background:linear-gradient(135deg,#1a4a7a,#232f3e)">Amazon</span>
            <p>バリューコマース経由で Amazon の商品リンクを掲載しています。</p>
          </div>
        </div>
        <ul class="rakuten-list" style="margin-top:28px">
          <li>塗料・ツールの商品ページをウィッシュリストに登録</li>
          <li>各サービスのアフィリエイトリンクをアプリ内ブラウザで開く</li>
          <li>購入済みフラグで管理状況を把握</li>
          <li>カラーマスター・ツールマスターと連動した自動登録</li>
        </ul>
      </div>
    </section>

    <!-- 対象ユーザー -->
    <section class="section section-alt" id="target">
      <div class="container">
        <h2 class="section-title">こんな方におすすめ</h2>
        <div class="target-grid">
          <div class="target-card">
            <span class="target-icon">🏆</span>
            <p>製作の過程を詳細に記録したい方</p>
          </div>
          <div class="target-card">
            <span class="target-icon">🎨</span>
            <p>使用した塗料・混色レシピを管理したい方</p>
          </div>
          <div class="target-card">
            <span class="target-icon">📸</span>
            <p>完成写真を整理して振り返りたい方</p>
          </div>
          <div class="target-card">
            <span class="target-icon">🛒</span>
            <p>欲しいアイテムをリスト管理したい方</p>
          </div>
          <div class="target-card">
            <span class="target-icon">📱</span>
            <p>製作記録をSNSで発信・共有したい方</p>
          </div>
          <div class="target-card">
            <span class="target-icon">🌐</span>
            <p>自分の作品を広く公開・アーカイブしたい方</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 開発情報 -->
    <section class="section" id="info">
      <div class="container">
        <h2 class="section-title">開発情報</h2>
        <table class="info-table">
          <tbody>
            <tr>
              <th>アプリ名</th>
              <td>BuildChronicle</td>
            </tr>
            <tr>
              <th>対応OS</th>
              <td>Android / iOS（未定）/ Windows（開発中）</td>
            </tr>
            <tr>
              <th>開発環境</th>
              <td>.NET MAUI（.NET 10）</td>
            </tr>
            <tr>
              <th>価格</th>
              <td>基本無料（一部機能は有料プラン）</td>
            </tr>
            <tr>
              <th>ステータス</th>
              <td>開発中</td>
            </tr>
            <tr>
              <th>リリース予定</th>
              <td>2026年夏</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- 規約・ポリシーリンク -->
    <section class="section section-alt" id="legal">
      <div class="container">
        <h2 class="section-title">規約・ポリシー・開発者情報</h2>
        <div class="legal-cards">
          <a class="legal-card" href="/apps/buildchronicle-privacy">
            <span class="legal-icon">🔒</span>
            <div>
              <h3>プライバシーポリシー</h3>
              <p>個人情報の取り扱いについて</p>
            </div>
            <span class="legal-arrow">→</span>
          </a>
          <a class="legal-card" href="/apps/buildchronicle-terms">
            <span class="legal-icon">📄</span>
            <div>
              <h3>利用規約</h3>
              <p>アプリご利用の条件について</p>
            </div>
            <span class="legal-arrow">→</span>
          </a>
        </div>
        <div class="developer-info">
          <h3>開発者情報</h3>
          <p>開発者：The Hobby Garage（agon1018）</p>
          <p>お問い合わせ：<a href="mailto:agon1018.studio@gmail.com">agon1018.studio@gmail.com</a></p>
        </div>
      </div>
    </section>

    <!-- フッター -->
    <footer class="footer">
      <p>© 2025 BuildChronicle. All rights reserved.</p>
      <p class="footer-links">
        <a href="/apps/buildchronicle-privacy">プライバシーポリシー</a>
        <span>|</span>
        <a href="/apps/buildchronicle-terms">利用規約</a>
      </p>
    </footer>
  </main>
  </RoomSidebar>
</Layout>

<style>
  :root {
    --primary: #2563eb;
    --primary-dark: #1d4ed8;
    --accent: #f59e0b;
    --bg: #f8fafc;
    --bg-alt: #e8f0fe;
    --text: #1e293b;
    --text-muted: #64748b;
    --card-bg: #ffffff;
    --border: #e2e8f0;
    --hero-bg: linear-gradient(135deg, #1e3a8a 0%, #2563eb 60%, #7c3aed 100%);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: 'Segoe UI', 'Noto Sans JP', sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
  }

  /* ヒーロー */
  .hero {
    background: var(--hero-bg);
    color: white;
    padding: 80px 20px 60px;
    text-align: center;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .app-icon-placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100px;
    height: 100px;
    background: rgba(255, 255, 255, 0.15);
    border: 3px solid rgba(255, 255, 255, 0.4);
    border-radius: 24px;
    font-size: 2.2rem;
    font-weight: 900;
    letter-spacing: -1px;
    margin-bottom: 24px;
  }

  .hero h1 {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 16px;
    letter-spacing: -1px;
  }

  .tagline {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 8px;
    opacity: 0.95;
  }

  .sub-tagline {
    font-size: 1rem;
    opacity: 0.8;
    margin-bottom: 28px;
  }

  .badge-area {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .badge {
    background: rgba(245, 158, 11, 0.9);
    color: white;
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .badge.platform {
    background: rgba(255, 255, 255, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.5);
  }

  .quick-jump {
    max-width: 960px;
    margin: 14px auto 0;
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 16px;
    box-shadow: 0 6px 16px rgba(29, 78, 216, 0.08);
  }

  .quick-jump p {
    margin: 0 0 8px;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--primary-dark);
    letter-spacing: 0.05em;
  }

  .quick-jump ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .quick-jump a {
    display: inline-block;
    text-decoration: none;
    color: #1d4ed8;
    font-size: 0.84rem;
    font-weight: 700;
    border: 1px solid #c4d5f5;
    border-radius: 999px;
    padding: 6px 10px;
    background: #f4f8ff;
  }

  .quick-jump a:hover,
  .quick-jump a:focus-visible {
    border-color: #8eb0ea;
    background: #ecf3ff;
    outline: none;
  }

  /* セクション共通 */
  .section {
    padding: 64px 20px;
  }

  .section-alt {
    background: var(--bg-alt);
  }

  .container {
    max-width: 960px;
    margin: 0 auto;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 800;
    text-align: center;
    margin-bottom: 12px;
    color: var(--primary-dark);
    position: relative;
    padding-bottom: 16px;
  }

  .section-title::after {
    content: '';
    display: block;
    width: 48px;
    height: 4px;
    background: var(--accent);
    border-radius: 2px;
    margin: 12px auto 0;
  }

  .section-desc {
    text-align: center;
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.9;
    margin-top: 24px;
  }

  /* 機能カード詳細 */
  .fd-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-top: 40px;
  }

  .fd-card {
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.07);
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
  }

  .fd-card:hover {
