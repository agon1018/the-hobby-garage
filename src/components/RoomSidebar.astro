---
interface BreadcrumbItem {
  href?: string;
  label: string;
}

interface Props {
  currentPath?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const { currentPath: _currentPath = '', breadcrumbs = [] } = Astro.props;
---

<div class="room-layout">
  <div class="room-content">
    {breadcrumbs.length > 0 && (
      <nav class="room-breadcrumb" aria-label="パンくず">
        <p class="room-breadcrumb-label">現在地</p>
        <ol>
          {breadcrumbs.map((item, index) => (
            <li>
              {index < breadcrumbs.length - 1 && item.href ? (
                <a href={item.href}>{item.label}</a>
              ) : (
                <span aria-current="page">{item.label}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>
    )}
    <slot />
  </div>
</div>

<style>
  .room-layout {
    display: block;
  }

  .room-content {
    min-width: 0;
  }

  .room-breadcrumb {
    max-width: 980px;
    margin: 0 auto 0.95rem;
    padding: 0.72rem 0.85rem;
    border: 1px solid #cfdbef;
    border-radius: 0.78rem;
    background: linear-gradient(180deg, #f6f9ff 0%, #eef4ff 100%);
    box-shadow: 0 8px 18px rgba(30, 58, 138, 0.08);
  }

  .room-breadcrumb-label {
    margin: 0 0 0.45rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #39588a;
    text-transform: uppercase;
  }

  .room-breadcrumb ol {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.48rem;
    color: #324862;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .room-breadcrumb li {
    display: inline-flex;
    align-items: center;
    gap: 0.48rem;
  }

  .room-breadcrumb li:not(:last-child)::after {
    content: '›';
    color: #5f78a0;
    font-weight: 400;
  }

  .room-breadcrumb a {
    color: #1f4ca0;
    text-decoration: none;
    padding: 0.1rem 0.15rem;
    border-radius: 0.32rem;
  }

  .room-breadcrumb a:hover,
  .room-breadcrumb a:focus-visible {
    background: #dfeaff;
    outline: none;
  }

  .room-breadcrumb span {
    color: #182c4f;
    font-weight: 800;
  }

  @media (max-width: 900px) {
    .room-layout {
      gap: 0;
    }

    .room-breadcrumb {
      margin: 0 auto 0.72rem;
      padding: 0.56rem 0.64rem;
      border-radius: 0.62rem;
    }

    .room-breadcrumb-label {
      font-size: 0.7rem;
      margin-bottom: 0.34rem;
    }

    .room-breadcrumb ol {
      font-size: 0.86rem;
      gap: 0.36rem;
    }
  }
</style>
